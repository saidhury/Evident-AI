{
  "version": 2,
  "name": "traceable-ai-compliance-agent",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "includeFiles": [
          "src/**",
          "frontend/**",
          "data/**",
          "config.example.yaml"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
